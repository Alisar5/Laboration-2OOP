<Window x:Class="Laboration_2OOP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Laboration_2OOP"
        mc:Ignorable="d"
               Title="{Binding WindowTitle}"
        Height="620"
        Width="1000">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="243*"/>
            <ColumnDefinition Width="247*"/>
        </Grid.ColumnDefinitions>
        <TabControl Grid.ColumnSpan="2">
            <TextBlock Text="{Binding TestText}" Margin="10"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="10,35,10,10"/>

            <!-- ========================= -->
            <!-- UC1: Anmälningar           -->
            <!-- ========================= -->
            <TabItem Header="Anmälningar (UC1)">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Anmälningar.SectionTitle}" Margin="10"/>

                    <GroupBox Header="Medlemmar" Grid.Column="0" Margin="0,0,10,0">
                        <ListBox x:Name="MembersList_UC1"
                                 ItemsSource="{Binding Anmälningar.Medlemmar}"
                                 SelectedItem="{Binding Anmälningar.ValdMedlem}" DisplayMemberPath="DisplayText"/>
                    </GroupBox>

                    <GroupBox Header="Spelträffar (kommande)" Grid.Column="1" Margin="0,0,10,0">
                        <ListBox x:Name="EventsList_UC1"
                               ItemsSource="{Binding Anmälningar.Spelträffar}"
                               SelectedItem="{Binding Anmälningar.ValdSpelträff}"
                                           DisplayMemberPath="DisplayText" />
                        
                    </GroupBox>

                    <GroupBox Header="Deltagare (vald träff)" Grid.Column="2" Margin="0,0,10,0">
                        <ListBox x:Name="ParticipantsList_UC1"
                                 ItemsSource="{Binding Anmälningar.Deltagare}"/>
                    </GroupBox>

                    <StackPanel Grid.Column="3">
                        <Button Content="Anmäl"
                                Height="35"
                                Margin="0,0,0,10"
                                Command="{Binding Anmälningar.AnmälCommand}"/>

                        <Button Content="Avanmäl"
                                Height="35"
                                Margin="0,0,0,20"
                                Command="{Binding Anmälningar.AvanmälCommand}"/>

                        <TextBlock Text="Status / Fel:" FontWeight="Bold"/>
                        <TextBox 
                                Height="360"
                                 Text="{Binding StatusMessage}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ========================= -->
            <!-- UC2: Spelträffar (LINQ sort) -->
            <!-- ========================= -->
            <TabItem Header="Spelträffar (UC2 + LINQ sort)">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Events.SectionTitle}" Margin="10"/>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <Button Content="Uppdatera lista (LINQ-sort lediga platser)"
                                Height="35"
                                Margin="0,0,0,10"
                                Command="{Binding Events.RefreshCommand}"/>
                        <ListBox x:Name="EventsList_UC2"
                                 ItemsSource="{Binding Events.EventTexts}"
                                 SelectedItem="{Binding Events.SelectedEvent}"
                                 DisplayMemberPath="DisplayText"
                                 Height="430"/>
                    </StackPanel>

                    <GroupBox Header="Skapa ny spelträff" Grid.Column="1">
                        <StackPanel Margin="10">
                            <TextBlock Text="Datum:"/>
                            <DatePicker x:Name="DatePicker"
                                        SelectedDate="{Binding Events.SelectedDate}" Margin="0,0,0,8"/>

                            <TextBlock Text="Tid (HH:mm):"/>
                            <TextBox x:Name="TimeBox"
                                      Text="{Binding Events.TimeText}" Margin="0,0,0,8"/>

                            <TextBlock Text="Plats:"/>
                            <TextBox x:Name="PlaceBox" 
                                     Text="{Binding Events.PlaceText}" Margin="0,0,0,8"/>

                            <TextBlock Text="Aktivitetstyp:"/>
                            <ComboBox x:Name="EventTypeCombo"
                                      ItemsSource="{Binding Events.AvailableEventTypes}"
                                      SelectedItem="{Binding Events.SelectedEventType}" Margin="0,0,0,8"/>

                            <TextBlock Text="Arrangör:"/>
                            <ComboBox x:Name="ArrangorCombo_UC2" 
                                      ItemsSource="{Binding Events.AvailableOrganizers}"
                                      SelectedItem="{Binding Events.SelectedOrganizer}"   Margin="0,0,0,8" 
                                      DisplayMemberPath="DisplayText"/>

                            <TextBlock Text="Spel:"/>
                            <ListBox x:Name="SpelList_UC2"
         ItemsSource="{Binding Events.AvailableGames}"
         local:ListBoxSelectedItemsBehavior.BoundSelectedItems="{Binding Events.SelectedGames}"
         Margin="0,0,0,8"
         Height="100"
         SelectionMode="Multiple"
         DisplayMemberPath="DisplayText"/>


                            <Button Content="Skapa spelträff"
                                    Height="35"
                                    Margin="0,10,0,0"
                                   Command="{Binding Events.SkapaCommand}"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- ========================= -->
            <!-- UC3: Medlemmar  nytt             -->
            <!-- ========================= -->
            <TabItem Header="Medlemmar (UC3)">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Members.SectionTitle}" Margin="10"/>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <CheckBox x:Name="OnlyActiveCheckbox"
                            Content="Visa endast aktiva (LINQ-filter)"
                             IsChecked="{Binding Members.OnlyActiveMembers}"
                                      Margin="0,0,0,10"/>
                        <ListBox x:Name="MembersList_UC3"
                              ItemsSource="{Binding Members.MemberTexts}"
                              SelectedItem="{Binding Members.SelectedMember}"
                               DisplayMemberPath="DisplayText"
                                 Height="420"/>

                    </StackPanel>

                    <GroupBox Header="Registrera / Uppdatera medlem" Grid.Column="1">
                        <StackPanel Margin="10">
                            <TextBlock Text="Förnamn:"/>
                            <TextBox x:Name="FirstNameBox"
                                     Text="{Binding Members.FirstName}" Margin="0,0,0,8"/>

                            <TextBlock Text="Efternamn:"/>
                            <TextBox x:Name="LastNameBox" 
                                     Text="{Binding Members.LastName}" Margin="0,0,0,8"/>

                            <TextBlock Text="Email:"/>
                            <TextBox x:Name="EmailBox"
                                     Text="{Binding Members.Email}" Margin="0,0,0,8"/>

                            <TextBlock Text="Telefon:"/>
                            <TextBox x:Name="PhoneBox" 
                                     Text="{Binding Members.Phone}" Margin="0,0,0,8"/>
                            <TextBlock Text="Roll:"/>
                            <ComboBox x:Name="Rollcompo_UC3" 
                                      ItemsSource="{Binding Members.AvailableRoles}"
                                      SelectedItem="{Binding Members.SelectedRole}" Margin="0,0,0,8"/>


                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="Registrera"
                                        Height="35"
                                        Width="120"
                                        Margin="0,0,10,0"
                                        Command="{Binding Members.RegistreraCommand}"/>

                                <Button Content="Uppdatera"
                                        Height="35"
                                        Width="120"
                                        Margin="0,0,10,0"
                                        Command="{Binding Members.UppdateraCommand}"/>

                                <Button Content="Avregistrera"
                                        Height="35"
                                        Width="120"
                                        Margin="0,0,10,0"
                                        Command="{Binding Members.AvregistreraCommand}"/>

                                <Button Content="Rensa"
                                        Height="35"
                                        Width="120"
                                        Margin="10,0,0,0"
                                         Command="{Binding Members.RensaCommand}"/>
                            </StackPanel>

                            <TextBlock Text="Tips: Välj en medlem i listan för att redigera."
                                       Margin="0,12,0,0"
                                       Foreground="Gray"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- ========================= -->
            <!-- Spel: Registrera/Uppdatera -->
            <!-- ========================= -->
            <TabItem Header="Spel (Registrera/Uppdatera)">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Games.SectionTitle}" Margin="10"/>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Alla spel" FontWeight="Bold" Margin="0,0,0,6"/>

                        <ListBox x:Name="AllGamesList"
                                 ItemsSource="{Binding Games.GameTexts}"
                                 SelectedItem="{Binding Games.SelectedGame}"
                                 Height="420"/>

                        <Button Content="Visa spel grupperade efter kategori (LINQ-group)"
                                Height="35"
                                Margin="0,10,0,0"
                                Command="{Binding Games.GrupperaCommand}"/>


                        <ListBox x:Name="GroupedGamesList"
                                 ItemsSource="{Binding Games.GroupedGames}" Height="130" Margin="0,10,0,0"/>
                    </StackPanel>

                    <GroupBox Header="Registrera / Uppdatera spel" Grid.Column="1">
                        <StackPanel Margin="10">
                            <TextBlock Text="Titel:"/>
                            <TextBox x:Name="GameTitleBox"
                                     Text="{Binding Games.GameTitle}" Margin="0,0,0,8"/>

                            <TextBlock Text="Kategori:"/>
                            <ComboBox x:Name="GameCategoryCombo"
                                      ItemsSource="{Binding Games.AvailableCategories}"
                                      SelectedItem="{Binding Games.SelectedCategory}" Margin="0,0,0,8"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <StackPanel Width="160" Margin="0,0,10,0">
                                    <TextBlock Text="Min spelare:"/>
                                    <TextBox x:Name="GameMinBox"
                                          Text="{Binding Games.MinPlayers}" Margin="0,0,0,8"/>


                                </StackPanel>
                                <StackPanel Width="160">
                                    <TextBlock Text="Max spelare:"/>
                                    <TextBox x:Name="GameMaxBox"
                                            Text="{Binding Games.MaxPlayers}" Margin="0,0,0,8"/>

                                </StackPanel>
                            </StackPanel>

                            <TextBlock Text="Speltid (minuter):"/>
                            <TextBox x:Name="GameTimeBox"
                                     Text="{Binding Games.GameTime}" Margin="0,0,0,8"/>


                            <TextBlock Text="Svårighetsgrad:"/>
                            <ComboBox x:Name="GameDifficultyCombo"
                                 ItemsSource="{Binding Games.AvailableDifficulties}"
                                  SelectedItem="{Binding Games.SelectedDifficulty}" Margin="0,0,0,8"/>

                            <TextBlock Text="Tillgänglighet:"/>
                            <ComboBox x:Name="GameAvailabilityCombo"
                                      ItemsSource="{Binding Games.AvailableAvailabilities}"
                                      SelectedItem="{Binding Games.SelectedAvailability}" Margin="0,0,0,8"/>

                            <TextBlock Text="Beskrivning:"/>
                            <TextBox x:Name="GameDescriptionBox"
                                     Text="{Binding Games.Description}"
                                     Height="90"
                                     Margin="0,0,0,8"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"/>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="Registrera spel"
                                        Width="140"
                                        Height="35"
                                        Margin="0,0,10,0"
                                         Command="{Binding Games.RegistreraCommand}"/>

                                <Button Content="Uppdatera spel"
                                        Width="140"
                                        Height="35"
                                        Margin="0,0,10,0"
                                        Command="{Binding Games.UppdateraCommand}"/>

                                <Button Content="Rensa"
                                        Width="100"
                                        Height="35"
                                        Command="{Binding Games.RensaCommand}"/>
                            </StackPanel>

                            <TextBlock Text="Tips: Välj ett spel i listan för att uppdatera."
                                       Margin="0,12,0,0"
                                       Foreground="Gray"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>